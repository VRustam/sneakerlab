# Public values, safe to expose to the browser when supplied by Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Do not use this in the browser or Flutter app. Normal customer
# flows do not require it; it is reserved for tightly controlled server tasks.
SUPABASE_SERVICE_ROLE_KEY=
